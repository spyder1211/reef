{
  "name": "reef",
  "productName": "Reef",
  "version": "1.0.2",
  "description": "A fast, tab-unlimited MySQL client for macOS",
  "main": "./out/main/index.js",
  "author": "spyder1211",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spyder1211/reef.git"
  },
  "homepage": "https://github.com/spyder1211/reef#readme",
  "bugs": {
    "url": "https://github.com/spyder1211/reef/issues"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist:mac": "electron-vite build && electron-builder --mac --arm64",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "mysql2": "^3.11.0",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@codemirror/lang-sql": "^6.10.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.3",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.15.5",
    "@uiw/react-codemirror": "^4.25.10",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^26.15.2",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0",
    "zustand": "^4.5.0"
  }
}
